{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/asdlc/on-prompt.sh\"", "timeout": 10 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/asdlc/on-write.sh\"", "timeout": 15 }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/asdlc/on-commit.sh\"", "timeout": 15 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/asdlc/on-format.sh\"", "timeout": 30 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/asdlc/on-stop.sh\"", "timeout": 300, "statusMessage": "ASDLC verify-gate" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/asdlc/on-subagent.sh\"", "timeout": 15 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/asdlc/on-session.sh\"", "timeout": 10 }
        ]
      }
    ]
  }
}
